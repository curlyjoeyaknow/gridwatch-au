# venv / build (anchored to repo root so docs/build/ is NOT ignored)
.venv/
/build/
/dist/
*.egg-info/
__pycache__/
*.py[cod]

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# generated artefacts — raw ledger and charts are large, never commit them
data/*
outputs/*
.ruff_cache/

# ── Exceptions: what CAN be committed ────────────────────────────────────────
# Keep directory placeholders
!data/.gitkeep
!outputs/.gitkeep

# Materialized JSON views are small (a few MB total) and ARE committed.
# They are the contract between the Python pipeline and the React dashboard.
# GitHub Actions refreshes them nightly and pushes the changes back to main.
!data/views/
!data/views/*.json

# Backfill progress log (useful to track history of runs)
!data/backfill.log

# ── Dashboard (React + Vite) ──────────────────────────────────────────────────
dashboard/node_modules/
dashboard/dist/
dashboard/.env
dashboard/.env.local

# ── Misc editor / OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
