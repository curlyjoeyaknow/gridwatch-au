# venv / build (anchored to repo root so docs/build/ is NOT ignored)
.venv/
/build/
/dist/
*.egg-info/
__pycache__/
*.py[cod]

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# generated artefacts (datasets, ledgers, charts) — never commit these
data/*
outputs/*
.ruff_cache/

# keep the directories themselves
!data/.gitkeep
!outputs/.gitkeep
